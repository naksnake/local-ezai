# ═══════════════════════════════════════════════════════════
# AI Service Configuration
# ═══════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Change the values marked with ⚠️
# 3. Never commit .env to git (it is in .gitignore)
# ═══════════════════════════════════════════════════════════


# ── Security (CHANGE THESE!) ──────────────────────────────
# ⚠️  Used as the API key for LiteLLM and OpenWebUI
LITELLM_MASTER_KEY=sk-ai-service-2024

# ⚠️  Secret key for OpenWebUI session tokens
WEBUI_SECRET_KEY=change-this-to-a-random-string

# API key for mcpo MCP tool server
MCP_API_KEY=local-tools-key


# ── Model Configuration ────────────────────────────────────
# HuggingFace model ID to use for the main chat LLM
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct

# Short name for the model (used in API calls and LiteLLM config)
CHAT_MODEL_NAME=qwen2.5-7b

# Max context window in tokens (reduce if running out of VRAM)
MAX_MODEL_LEN=4096

# Fraction of GPU VRAM to use (0.0 - 1.0)
# Reduce to 0.75 if you see CUDA out-of-memory errors
GPU_MEMORY_UTILIZATION=0.85


# ── Paths ──────────────────────────────────────────────────
# Where HuggingFace models are cached on the host
MODELS_DIR=${HOME}/ai-models/hf-cache

# Folder that agents can read/write via the filesystem MCP tool
DOCUMENTS_DIR=${HOME}/documents


# ── Qdrant RAG ─────────────────────────────────────────────
# Name of the default Qdrant collection for document search
RAG_COLLECTION=my-knowledge-base


# ── SearXNG ────────────────────────────────────────────────
# Change this to any random string for security
SEARXNG_SECRET=searxng-local-secret-change-this


# ── Optional: HuggingFace token ────────────────────────────
# Only needed for gated models (e.g. Llama, Gemma)
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
